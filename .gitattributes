# Force Unix line endings for all shell scripts and Python files
# This prevents Windows git from converting LF → CRLF on checkout,
# which would break bash scripts when copied to the Raspberry Pi.

*.sh        text eol=lf
*.py        text eol=lf
*.service   text eol=lf
*.txt       text eol=lf
*.md        text eol=lf
*.cfg       text eol=lf
*.conf      text eol=lf
*.gitignore text eol=lf

# Windows batch files keep CRLF
*.bat       text eol=crlf
